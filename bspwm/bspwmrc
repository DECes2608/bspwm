#! /bin/sh
pgrep -x sxhkd > /dev/null || sxhkd &

bspc monitor -d 1 2 3 4 5 6 7 8

bspc config border_width         2
bspc config window_gap          12
bspc config top_padding 35

bspc config split_ratio          0.5

#tek pencere varken barı kapsamayacak şekilde ekranı kaplar gapler olmaz
bspc config single_monocle true

#tek pencere varken ekran kenarındaki odak modunu kaldırır
bspc config borderless_monocle   true

#tam ekranda hiç bir boşluk olmaz
bspc config gapless_monocle      true

bspc config focus_follows_pointer true
#bspc config pointer_follows_focus true



bspc config focused_border_color "#022d5b"
bspc config normal_border_color "#000000"
bspc config active_border_color "#4a729e"
bspc config gapless_monocle "#429af7"

bspc rule -a "steam" desktop='^6' 
bspc rule -a "librewolf" desktop='^1' follow=on
bspc rule -a "Spotify" desktop='^2'
bspc rule -a "kitty" desktop='^4' follow=on
bspc rule -a "obsidian" desktop='^3'
bspc rule -a "Thunar" desktop='^5' follow=on
bspc rule -a "Nautilus" desktop='^5' follow=on
bspc rule -a "firefox" desktop='^1' follow=on
bspc rule -a "brave-browser" desktop='^1' follow=on

bspc rule -a "Nm-connection-editor" state=floating follow=on
bspc rule -a copyq state=floating follow=on
bspc rule -a "Blueman-manager" state=floating follow=on

xrdb -merge ~/.Xresources &
wal -R &

~/.config/polybar/launch.sh &
xset b off &
xinput set-prop 10 "libinput Accel Speed" -0.5 &
compfy -fb --backend glx --config ~/.config/compfy/compfy.conf &
feh --bg-fill ~/wallpaper/clouds.png &
pgrep -u $(whoami) -f "dunst" || dunst &
pgrep -u $(whoami) -f "lxsession" || lxsession -s BSPWM -e BSPWM &
xsetroot -cursor_name left_ptr &
numlockx on &
copyq &
xset r rate 200 35 &
nm-applet &
blueman-applet &
